COMPOSE_PROJECT_NAME=calen
TZ=Asia/Seoul
OCI_FRONTEND_BIND_HOST=127.0.0.1
OCI_FRONTEND_BIND_PORT=8081
OCI_BACKEND_BIND_HOST=127.0.0.1
OCI_BACKEND_BIND_PORT=8080
OCI_DB_BIND_HOST=127.0.0.1
OCI_DB_BIND_PORT=3306
OCI_MINIO_CONSOLE_BIND_HOST=127.0.0.1
OCI_MINIO_CONSOLE_BIND_PORT=9001

APP_EXTERNAL_PORT=8080
APP_EXTERNAL_URL=http://localhost:8080

BACKEND_INTERNAL_HOST=backend
BACKEND_INTERNAL_PORT=8080

DB_NAME=calen
DB_USER=calen
DB_PASSWORD=calen1234
DB_ROOT_PASSWORD=change-me-db-root-password
DB_INTERNAL_HOST=mariadb
DB_INTERNAL_PORT=3306

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_CLOUD_BUCKET=budgetjourneybucket
MINIO_API_INTERNAL_URL=http://minio:9000
MINIO_API_EXTERNAL_PORT=9000
MINIO_CONSOLE_EXTERNAL_PORT=9001
MINIO_CONSOLE_EXTERNAL_URL=http://localhost:9001

APP_SEED_ENABLED=true
JWT_KEY=change-me-remember-me-key
TRAVEL_EXCHANGE_RATE_BASE_URL=https://api.frankfurter.dev/v1
TRAVEL_EXCHANGE_RATE_CACHE_MINUTES=30
TRAVEL_PRESIGNED_UPLOAD_ENABLED=false
LEDGER_OCR_ENABLED=false
LEDGER_OCR_BASE_URL=http://127.0.0.1:8765
LEDGER_OCR_API_KEY=change-me-ocr-api-key
LEDGER_OCR_CONNECT_TIMEOUT=3s
LEDGER_OCR_READ_TIMEOUT=45s
LEDGER_OCR_MAX_FILE_SIZE=10MB
H2_CONSOLE_ENABLED=false
DATA_OPS_BACKUP_WORKDIR=/opt/calen-backup
DATA_OPS_BACKUP_REMOTE_NAME=db-backup
DATA_OPS_BACKUP_REMOTE_DIR=calen-db-backups
DATA_OPS_BACKUP_HOST_PATH=/opt/calen-backup
DATA_OPS_RCLONE_CONFIG_HOST_PATH=/home/ubuntu/.config/rclone
