COMPOSE_PROJECT_NAME=calen
TZ=Asia/Seoul

# Local bind ports
OCI_FRONTEND_BIND_HOST=127.0.0.1
OCI_FRONTEND_BIND_PORT=8081
OCI_BACKEND_BIND_HOST=127.0.0.1
OCI_BACKEND_BIND_PORT=8080
OCI_DB_BIND_HOST=127.0.0.1
OCI_DB_BIND_PORT=3306
OCI_MINIO_CONSOLE_BIND_HOST=127.0.0.1
OCI_MINIO_CONSOLE_BIND_PORT=9001
APP_EXTERNAL_PORT=8080
APP_EXTERNAL_URL=http://localhost:8080
BACKEND_INTERNAL_HOST=backend
BACKEND_INTERNAL_PORT=8080

# Compose database container values
DB_NAME=calen
DB_USER=calen
DB_PASSWORD=calen1234
DB_ROOT_PASSWORD=change-me-db-root-password
DB_INTERNAL_HOST=mariadb
DB_INTERNAL_PORT=3306

# Spring datasource values used by backend/src/main/resources/application.yml
DB_URL=jdbc:mariadb://mariadb:3306/calen?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Seoul
DB_DRIVER=org.mariadb.jdbc.Driver
DB_ID=calen
DB_PASS=calen1234
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
H2_CONSOLE_ENABLED=false

# MinIO / object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_CLOUD_BUCKET=budgetjourneybucket
MINIO_WORKSPACE_BUCKET=calen-workspace
MINIO_API=http://minio:9000
MINIO_PUBLIC_API=http://localhost:9000
MINIO_NAME=minioadmin
MINIO_SECRET=change-me-minio-password
MINIO_API_INTERNAL_URL=http://minio:9000
MINIO_API_EXTERNAL_PORT=9000
MINIO_CONSOLE_EXTERNAL_PORT=9001
MINIO_CONSOLE_EXTERNAL_URL=http://localhost:9001
MINIO_PRESIGNED_URL_EXPIRY_SECONDS=6000

# Security/session
APP_SEED_ENABLED=true
JWT_KEY=change-me-remember-me-key
JWT_EXPIRE=300000000

# Travel integrations and media
TRAVEL_EXCHANGE_RATE_BASE_URL=https://api.frankfurter.dev/v1
TRAVEL_EXCHANGE_RATE_CACHE_MINUTES=30
TRAVEL_REVERSE_GEOCODE_BASE_URL=https://nominatim.openstreetmap.org/reverse
TRAVEL_REVERSE_GEOCODE_USER_AGENT=TravelLedger/1.0 (+https://www.innoutdrive.space)
TRAVEL_REVERSE_GEOCODE_REQUEST_MIN_INTERVAL_MS=1200
TRAVEL_REVERSE_GEOCODE_CACHE_TTL_HOURS=24
TRAVEL_SUMMARY_CACHE_TTL_SECONDS=60
TRAVEL_MEDIA_DOWNLOAD_CACHE_TTL_SECONDS=300
TRAVEL_THUMBNAIL_BACKFILL_ENABLED=true
TRAVEL_THUMBNAIL_BACKFILL_FIXED_DELAY_MS=900000
TRAVEL_THUMBNAIL_BACKFILL_INITIAL_DELAY_MS=300000
TRAVEL_THUMBNAIL_BACKFILL_PAGE_SIZE=25
TRAVEL_THUMBNAIL_BACKFILL_MAX_ITEMS_PER_RUN=100
TRAVEL_MEDIA_STORAGE_PATH=/app/uploads/travel-media
TRAVEL_MEDIA_OBJECT_PREFIX=travel-media
TRAVEL_PRESIGNED_UPLOAD_ENABLED=false

# Ledger OCR
LEDGER_OCR_ENABLED=false
LEDGER_OCR_WORKFLOW_URL=http://127.0.0.1:5678/webhook/ocr-gemma-json
LEDGER_OCR_BASE_URL=http://127.0.0.1:8765
LEDGER_OCR_API_KEY=change-me-ocr-api-key
LEDGER_OCR_CONNECT_TIMEOUT=3s
LEDGER_OCR_READ_TIMEOUT=90s
LEDGER_OCR_MAX_FILE_SIZE=10MB

# Ledger AI analysis. LM Studio default address is the local server shown in LM Studio.
APP_LEDGER_AI_ENABLED=true
APP_LEDGER_AI_PROVIDER=lmstudio
APP_LEDGER_AI_MODEL=gemma4:e12b
APP_LEDGER_AI_LMSTUDIO_BASE_URL=http://172.18.240.1:1234
# Use /v1/chat/completions if you switch LM Studio to the OpenAI-compatible endpoint.
APP_LEDGER_AI_LMSTUDIO_CHAT_PATH=/api/v1/chat
APP_LEDGER_AI_LMSTUDIO_API_KEY=
APP_LEDGER_AI_TEMPERATURE=0.2
APP_LEDGER_AI_MAX_TOKENS=2048
APP_LEDGER_AI_CONNECT_TIMEOUT=3s
APP_LEDGER_AI_READ_TIMEOUT=120s
# Optional n8n provider values. Set APP_LEDGER_AI_PROVIDER=n8n to use them.
APP_LEDGER_AI_WORKFLOW_URL=http://127.0.0.1:5678/webhook/travelledger-ledger-ai
APP_LEDGER_AI_API_KEY=change-me-ledger-ai-api-key
APP_LEDGER_AI_API_KEY_HEADER=X-TravelLedger-AI-Key

# Redis cache/state stores
REDIS_CACHE_HOST=redis
REDIS_CACHE_PORT=6379
REDIS_CACHE_PASSWORD=
REDIS_CACHE_DATABASE=0
REDIS_CACHE_SSL=false
REDIS_STATE_HOST=redis
REDIS_STATE_PORT=6379
REDIS_STATE_PASSWORD=
REDIS_STATE_DATABASE=0
REDIS_STATE_SSL=false

# Family/support uploads
FAMILY_MEDIA_STORAGE_PATH=/app/uploads/family-media
FAMILY_MEDIA_OBJECT_PREFIX=family-media
SUPPORT_ATTACHMENT_STORAGE_PATH=/app/uploads/support-inquiries

# Data operations and backup automation
DATA_OPS_BACKUP_WORKDIR=/opt/calen-backup
DATA_OPS_BACKUP_REMOTE_NAME=db-backup
DATA_OPS_BACKUP_REMOTE_DIR=calen-db-backups
DATA_OPS_MINIO_BACKUP_REMOTE_DIR=calen-minio-backups
DATA_OPS_RCLONE_CONFIG_PATH=/app/.config/rclone/rclone.conf
DATA_OPS_BACKUP_ZONE=Asia/Seoul
DATA_OPS_DB_BACKUP_ENABLED=false
DATA_OPS_DB_BACKUP_CRON=0 0 0 * * *
DATA_OPS_MINIO_BACKUP_ENABLED=false
DATA_OPS_MINIO_BACKUP_CRON=0 30 0 * * *
DATA_OPS_BACKUP_HOST_PATH=/opt/calen-backup
DATA_OPS_RCLONE_CONFIG_HOST_PATH=/home/ubuntu/.config/rclone
