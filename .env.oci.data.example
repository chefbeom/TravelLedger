COMPOSE_PROJECT_NAME=calen-data
TZ=Asia/Seoul

DATA_DB_BIND_HOST=0.0.0.0
DATA_DB_BIND_PORT=3306
DATA_MINIO_API_BIND_HOST=0.0.0.0
DATA_MINIO_API_BIND_PORT=9000
DATA_MINIO_CONSOLE_BIND_HOST=0.0.0.0
DATA_MINIO_CONSOLE_BIND_PORT=9001

DB_NAME=calen
DB_USER=calen
DB_PASSWORD=change-me-db-user-password
DB_ROOT_PASSWORD=change-me-db-root-password

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_CLOUD_BUCKET=budgetjourneybucket
MINIO_API_INTERNAL_URL=http://minio:9000
MINIO_CONSOLE_EXTERNAL_URL=http://127.0.0.1:9001
# Optional encryption for deploy/oci/scripts/backup-to-gdrive.sh.
# Use none, age, or gpg. Keep private keys/passphrases outside this file and outside the backup remote.
BACKUP_ENCRYPTION_MODE=none
BACKUP_AGE_RECIPIENTS=
BACKUP_GPG_RECIPIENT=
KEEP_PLAINTEXT_AFTER_ENCRYPTION=false

