GENERIC_TIMEZONE=Asia/Seoul
TZ=Asia/Seoul

# Default is localhost-only. Use 192.168.35.64 only after approving LAN exposure.
N8N_BIND_ADDRESS=127.0.0.1
N8N_HOST=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://127.0.0.1:5678/

# Generated by install-n8n.sh when blank.
N8N_ENCRYPTION_KEY=

# Generated by install-n8n.sh when blank. Set the same value in backend APP_LEDGER_AI_API_KEY.
TRAVELLEDGER_AI_WEBHOOK_KEY=

# Workflow import is safe by default. Publishing activates the production webhook.
IMPORT_TRAVELLEDGER_AI_WORKFLOW=true
PUBLISH_TRAVELLEDGER_AI_WORKFLOW=false

# Local LLM API settings. Leave blank until the model server is ready.
# Expected default shape is OpenAI-compatible: POST {LOCAL_LLM_BASE_URL}/v1/chat/completions
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=gemma4:e12b